# ═══════════════════════════════════════════════════════════════
# VIGIA Monorepo — .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Build outputs ───────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── Environment files ───────────────────────────────────────
# NUNCA ignorar .env.example (es documentación)
.env
.env.local
.env.*.local
!.env.example

# ─── Lock files ──────────────────────────────────────────────
# pnpm-lock.yaml → SE COMMITEA (NO está aquí)
package-lock.json
yarn.lock

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ─── Test & Coverage ─────────────────────────────────────────
coverage/
.nyc_output/

# ─── IDE ─────────────────────────────────────────────────────
# Se ignora todo excepto settings y extensions compartidas
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ─── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Python (services/ocr, services/bio) ────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.mypy_cache/

# ─── Docker ──────────────────────────────────────────────────
# No ignorar docker-compose.yml ni Dockerfiles
*.pid

# ─── TypeORM migrations (solo .js compilados) ────────────────
apps/backend/src/core/database/migrations/*.js
apps/backend/src/core/database/migrations/*.js.map

# ─── Claude Code (configuración local del desarrollador) ─────
.claude/
.claudeignore
CLAUDE.md