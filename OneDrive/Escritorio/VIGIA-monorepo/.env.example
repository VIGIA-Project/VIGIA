# ============================================================
# VIGIA - Variables de referencia del monorepo
# Copia este archivo como .env en cada app que lo necesite
# ============================================================

# Backend → apps/backend/.env
APP_PORT=3000
NODE_ENV=development
JWT_SECRET=cambiar-en-produccion
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET=cambiar-en-produccion
JWT_REFRESH_EXPIRATION=86400

# Database (compartida)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=vigia_user
DB_PASSWORD=vigia_secret
DB_NAME=vigia_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Frontend → apps/frontend/.env
VITE_API_URL=http://localhost:3000/api/v1