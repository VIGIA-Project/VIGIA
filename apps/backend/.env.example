# apps/backend/.env
# Copiar como apps/backend/.env y ajustar valores.
# Este archivo NUNCA debe escapar a la raíz del repo (ver rules-backend.md).

# ── Base de datos ────────────────────────────────────────────
# Postgres local (recomendado para desarrollo, ver README raíz para
# la alternativa con docker-compose, que usa el puerto 5434).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=admin
DB_NAME=vigia_db
# true en desarrollo: TypeORM crea/actualiza tablas automáticamente
# a partir de las entidades (autoLoadEntities). Los schemas "auth" y
# "registry" los crea un hook aparte (ensureSchemas) antes de sincronizar.
DB_SYNCHRONIZE=true
DB_LOGGING=true

# ── Autenticación ────────────────────────────────────────────
JWT_SECRET=vigia-dev-secret-2026
JWT_EXPIRATION=8h
BCRYPT_ROUNDS=10

# ── Aplicación ───────────────────────────────────────────────
APP_PORT=3000
NODE_ENV=development
