# apps/frontend/.env.example
# ══════════════════════════════════════════════════════════════
# VIGIA Frontend — Variables de Entorno
# ══════════════════════════════════════════════════════════════
# Copiar este archivo como .env.local y ajustar valores

# URL base del API Backend (sin trailing slash).
# El backend NestJS corre por defecto en el puerto 3000 (ver apps/backend/.env).
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Entorno (development | staging | production)
VITE_APP_ENV=development

# Nombre de la aplicación (usado en títulos y meta tags)
VITE_APP_NAME=VIGIA

# Versión (se puede inyectar desde CI/CD)
VITE_APP_VERSION=0.1.0
