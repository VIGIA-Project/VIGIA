PORT=8000
LOG_LEVEL=info

# Umbral de confianza del OCR local. Por debajo de este valor se intenta
# el fallback con Gemini antes de devolver el resultado al backend.
OCR_CONFIDENCE_THRESHOLD=0.7

# Modelos usados por fast-alpr (detector + OCR locales)
ALPR_DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end
ALPR_OCR_MODEL=cct-xs-v1-global-model

# Fallback en la nube (Opción C)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Timeout duro para no bloquear la garita si Gemini/la conexión están lentos
GEMINI_TIMEOUT_SECONDS=1.5
